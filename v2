LogService.MessageOut:Connect(function(m, t)
    local msg = m:lower()
    -- Проверка биомов (только логи)
    for name, enabled in pairs(settings.biomes) do
        if enabled and msg:find(name:lower()) then
            notify("🚨 БИОМ: " .. name .. "\nЛог: " .. m)
        end
    end
    -- Проверка мерчантов
    for name, enabled in pairs(settings.merchants) do
        if enabled and msg:find(name:lower() .. " has arrived") then
            notify("🏪 МЕРЧАНТ: " .. name)
        end
    end
end)

TextChatService.OnIncomingMessage = function(m: TextChatMessage)
    local msg = m.Text:lower()
    for name, enabled in pairs(settings.merchants) do
        if enabled and msg:find(name:lower() .. " has arrived") then
            notify("💬 [CHAT] МЕРЧАНТ: " .. name)
        end
    end
end

