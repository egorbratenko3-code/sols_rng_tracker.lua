-- Переключатели (Чекбоксы) для биомов
local function AddToggle(parent, name, tableKey, subKey, y)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(0.95, 0, 0, 30)
    btn.Position = UDim2.new(0, 0, 0, y)
    btn.BackgroundColor3 = settings[tableKey][subKey] and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(150, 50, 50)
    btn.Text = name .. (settings[tableKey][subKey] and " [ON]" or " [OFF]")
    btn.TextColor3 = Color3.white
    
    btn.MouseButton1Click:Connect(function()
        settings[tableKey][subKey] = not settings[tableKey][subKey]
        btn.BackgroundColor3 = settings[tableKey][subKey] and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(150, 50, 50)
        btn.Text = name .. (settings[tableKey][subKey] and " [ON]" or " [OFF]")
    end)
    return btn
end

