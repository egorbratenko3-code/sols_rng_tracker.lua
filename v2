local function notify(msg)
    if target_id == "" then return end
    LogDisplay.Text = "["..os.date("%X").."] Sent: "..msg.."\n"..LogDisplay.Text
    local url = "https://api.telegram.org/bot"..BOT_TOKEN.."/sendMessage?chat_id="..target_id.."&text="..HttpService:UrlEncode(msg)
    pcall(function()
        local req = (syn and syn.request) or request or http_request
        if req then req({Url = url, Method = "GET"}) else HttpService:GetAsync(url) end
    end)
end

IDInput.FocusLost:Connect(function(ep)
    if ep then
        target_id = IDInput.Text
        notify("📡 Устройство успешно привязано к ID "..target_id)
    end
end)

