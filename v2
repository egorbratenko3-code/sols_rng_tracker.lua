-- ==========================================
-- ФУНКЦИЯ УВЕДОМЛЕНИЯ
-- ==========================================
local lastMsg = ""
local function notify(msg)
    if target_id == "" or msg == lastMsg then return end
    lastMsg = msg
    local url = "https://api.telegram.org/bot"..BOT_TOKEN.."/sendMessage?chat_id="..target_id.."&text="..HttpService:UrlEncode(msg)
    pcall(function()
        local req = (syn and syn.request) or request or http_request
        if req then req({Url = url, Method = "GET"}) else HttpService:GetAsync(url) end
    end)
    updateLogs("[Sent to TG]: " .. msg)
end

idBox.FocusLost:Connect(function(ep)
    if ep then 
        target_id = idBox.Text 
        updateLogs("ID Saved: " .. target_id)
        notify("📡 Устройство подключено к Elite Tracker!")
    end
end)

