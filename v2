local function CreatePage(name)
    local p = Instance.new("ScrollingFrame")
    p.Name = name
    p.Parent = Container
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.Visible = false
    p.CanvasSize = UDim2.new(0, 0, 2, 0)
    p.ScrollBarThickness = 3
    Pages[name] = p
    return p
end

